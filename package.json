{
  "name": "icrashedmyplane",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=26.4.0"
  },
  "scripts": {
    "build": "run-p type-check \"build-only {@}\" --",
    "build-only": "vite build",
    "ci:build": "run-p type-check \"build-only {@}\" --",
    "ci:unit": "vitest --run",
    "dev": "vite",
    "doc": "npx typedoc --out docs src",
    "format": "prettier --write .",
    "lint:eslint": "eslint .",
    "lint:stylelint": "stylelint \"src/**/*.{vue,css,scss,sass}\"",
    "lint:oxlint": "oxlint -c oxlintrc.json src",
    "lint:knip": "knip",
    "lint": "run-s 'lint:*'",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:dev": "playwright test --ui",
    "test:unit": "vitest",
    "type-check": "vue-tsc --build"
  },
  "dependencies": {
    "@intlify/core-base": "^11.4.6",
    "@sentry/vue": "^10.60.0",
    "cldr-data": "^36.0.5",
    "cldrjs": "^0.5.5",
    "lodash-es": "^4.18.1",
    "normalize.css": "^8.0.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.38",
    "vue-i18n": "^11.4.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@pinia/testing": "^1.0.3",
    "@playwright/test": "^1.61.1",
    "@testing-library/vue": "^8.1.0",
    "@tsconfig/node22": "^22.0.5",
    "@types/cldrjs": "^0.4.29",
    "@types/jsdom": "^28.0.3",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^26.0.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/compiler-dom": "^3.5.38",
    "@vue/server-renderer": "^3.5.38",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.5.0",
    "eslint-plugin-vue": "^10.9.2",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "knip": "^6.20.0",
    "npm-run-all2": "^9.0.2",
    "oxlint": "^1.71.0",
    "postcss": "^8.5.15",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.4",
    "sass": "^1.101.0",
    "stylelint": "^17.13.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-vue-devtools": "^8.1.3",
    "vitest": "^4.1.9",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.5",
    "wrangler": "^4.112.0"
  },
  "packageManager": "pnpm@11.5.1"
}
