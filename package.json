{
  "name": "icrashedmyplane",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "run-p type-check \"build-only {@}\" --",
    "build-only": "vite build",
    "ci:build": "run-p type-check \"build-only {@}\" --",
    "ci:unit": "vitest --run",
    "dev": "vite",
    "doc": "npx typedoc --out docs src",
    "format": "prettier --write src/",
    "lint": "eslint . --fix",
    "preview": "vite preview",
    "stylelint": "stylelint \"src/**/*.{vue,css,scss,sass}\"",
    "test:e2e": "start-server-and-test 'vite preview --port 4173' http://localhost:4173 'cypress run --e2e'",
    "test:e2e:dev": "start-server-and-test 'vite dev --port 4173' http://localhost:4173 'cypress open --e2e'",
    "test:unit": "vitest",
    "type-check": "vue-tsc --build"
  },
  "dependencies": {
    "@bugsnag/browser-performance": "^2.12.0",
    "@bugsnag/js": "^8.2.0",
    "@bugsnag/plugin-vue": "^8.2.0",
    "cldr-data": "^36.0.2",
    "cldrjs": "^0.5.5",
    "lodash-es": "^4.17.21",
    "normalize.css": "^8.0.1",
    "pinia": "^3.0.2",
    "vue": "^3.5.13",
    "vue-i18n": "^11.1.3"
  },
  "devDependencies": {
    "@pinia/testing": "^1.0.1",
    "@rushstack/eslint-patch": "^1.11.0",
    "@testing-library/cypress": "^10.0.3",
    "@testing-library/vue": "^8.1.0",
    "@tsconfig/node22": "^22.0.1",
    "@types/cldrjs": "^0.4.28",
    "@types/jsdom": "^21.1.7",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.14.1",
    "@types/setimmediate": "^1.0.4",
    "@typescript-eslint/utils": "^8.30.1",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vitest/eslint-plugin": "^1.1.42",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.5.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "cypress": "^14.3.0",
    "cypress-vite": "^1.6.0",
    "eslint": "^9.24.0",
    "eslint-plugin-cypress": "^4.2.1",
    "eslint-plugin-vue": "^10.0.0",
    "jsdom": "^26.1.0",
    "npm-run-all2": "^7.0.2",
    "postcss": "^8.5.3",
    "postcss-html": "^1.8.0",
    "prettier": "^3.5.3",
    "sass": "^1.86.3",
    "setimmediate": "^1.0.5",
    "start-server-and-test": "^2.0.11",
    "stylelint": "^16.18.0",
    "stylelint-config-recess-order": "^6.0.0",
    "stylelint-config-recommended-scss": "^14.1.0",
    "stylelint-config-recommended-vue": "^1.6.0",
    "stylelint-config-standard-scss": "^14.0.0",
    "typedoc": "^0.28.2",
    "typescript": "^5.8.3",
    "vite": "^6.3.1",
    "vite-plugin-vue-devtools": "^7.7.5",
    "vitest": "^3.1.1",
    "vue-tsc": "^2.2.8"
