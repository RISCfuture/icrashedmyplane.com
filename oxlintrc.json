{
  "$schema": "https://raw.githubusercontent.com/nicolo-ribaudo/oxc-project/json-schemas/npm/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "nursery": "off",
    "pedantic": "error",
    "perf": "error",
    "restriction": "off",
    "style": "error",
    "suspicious": "error"
  },
  "rules": {
    "capitalized-comments": "off",
    "consistent-type-imports": "off",
    "curly": "off",
    "default-case": "off",
    "func-names": "off",
    "func-style": "off",
    "id-length": "off",
    "init-declarations": "off",
    "max-classes-per-file": "off",
    "max-lines-per-function": "off",
    "max-params": "off",
    "max-statements": "off",
    "no-accumulating-spread": "off",
    "no-duplicate-imports": "off",
    "max-lines": "off",
    "no-inline-comments": "off",
    "no-magic-numbers": "off",
    "no-negated-condition": "off",
    "no-param-reassign": "off",
    "no-shadow": "off",
    "no-ternary": "off",
    "no-undefined": "off",
    "no-void": "off",
    "parameter-properties": "off",
    "prefer-destructuring": "off",
    "prefer-enum-initializers": "off",
    "sort-imports": "off",
    "sort-keys": "off",
    "unicorn/consistent-function-scoping": "off",
    "unicorn/filename-case": "off",
    "unicorn/no-lonely-if": "off",
    "unicorn/no-null": "off",
    "unicorn/no-zero-fractions": "off",
    "unicorn/no-useless-undefined": "off",
    "unicorn/prefer-at": "off",
    "unicorn/prefer-global-this": "off",
    "unicorn/prefer-object-from-entries": "off",
    "unicorn/prefer-spread": "off",
    "unicorn/prefer-string-raw": "off",
    "unicorn/prefer-structured-clone": "off"
  },
  "ignorePatterns": ["dist", "node_modules", ".yarn", "cypress", "coverage"]
}
